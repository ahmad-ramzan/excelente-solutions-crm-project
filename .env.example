# Copy to .env (local) and set the same vars in Vercel → Project → Settings → Environment Variables.
# Values come from your Supabase project: Settings → API.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Secret — server only. NEVER prefix with NEXT_PUBLIC_. Bypasses row-level security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
